<section class="mx-auto w-full max-w-md rounded-2xl border border-[var(--color-border)] bg-white p-8 shadow-sm">
  <h1 class="mb-6 text-2xl font-semibold tracking-tight text-[var(--color-ink)]">Create your account</h1>

  <%= form_with model: @user, class: "space-y-4", data: { turbo: false } do |f| %>
    <div>
      <%= f.label :name, class: "mb-1 block text-sm font-medium text-[var(--color-ink)]" %>
      <%= f.text_field :name, class: "w-full rounded-lg border border-[var(--color-border)] px-3 py-2 focus:border-[var(--color-brand)] focus:outline-none" %>
      <% @user.errors.full_messages_for(:name).each do |message| %>
        <p class="mt-1 text-sm text-[var(--color-danger)]"><%= message %></p>
      <% end %>
    </div>

    <div>
      <%= f.label :email, class: "mb-1 block text-sm font-medium text-[var(--color-ink)]" %>
      <%= f.email_field :email, class: "w-full rounded-lg border border-[var(--color-border)] px-3 py-2 focus:border-[var(--color-brand)] focus:outline-none" %>
      <% @user.errors.full_messages_for(:email).each do |message| %>
        <p class="mt-1 text-sm text-[var(--color-danger)]"><%= message %></p>
      <% end %>
    </div>

    <div>
      <%= f.label :password, class: "mb-1 block text-sm font-medium text-[var(--color-ink)]" %>
      <%= f.password_field :password, class: "w-full rounded-lg border border-[var(--color-border)] px-3 py-2 focus:border-[var(--color-brand)] focus:outline-none" %>
      <% @user.errors.full_messages_for(:password).each do |message| %>
        <p class="mt-1 text-sm text-[var(--color-danger)]"><%= message %></p>
      <% end %>
    </div>

    <div>
      <%= f.label :password_confirmation, class: "mb-1 block text-sm font-medium text-[var(--color-ink)]" %>
      <%= f.password_field :password_confirmation, class: "w-full rounded-lg border border-[var(--color-border)] px-3 py-2 focus:border-[var(--color-brand)] focus:outline-none" %>
    </div>

    <%= f.submit "Sign up", class: "w-full rounded-lg bg-[var(--color-brand)] px-4 py-2 font-medium text-white transition hover:bg-[var(--color-brand-strong)]" %>
  <% end %>

  <p class="mt-6 text-sm text-[var(--color-muted)]">
    Already have an account?
    <%= link_to "Log in", new_session_path, class: "font-medium text-[var(--color-brand)] hover:underline" %>
  </p>
</section>

<article class="rounded-xl border border-[var(--color-border)] bg-white p-5 shadow-sm">
  <div class="mb-2 flex items-center justify-between">
    <h2 class="text-lg font-semibold text-[var(--color-ink)]"><%= feature.title %></h2>
    <p class="text-xs text-[var(--color-muted)]">by <%= feature.user.name %></p>
  </div>
  <p class="text-sm text-[var(--color-muted)]"><%= feature.description %></p>
</article>

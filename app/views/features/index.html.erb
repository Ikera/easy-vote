<section class="space-y-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-3xl font-semibold tracking-tight text-[var(--color-ink)]">Feature Requests</h1>
      <p class="mt-1 text-sm text-[var(--color-muted)]">Share ideas and vote on what should be built next.</p>
    </div>
  </div>

  <%= link_to "New feature", new_feature_path, data: { turbo_frame: "modal" }, class: "inline-flex rounded-lg bg-[var(--color-brand)] px-4 py-2 text-sm font-medium text-white hover:bg-[var(--color-brand-strong)]" %>

  <div id="features" class="space-y-4">
    <% @features.each do |feature| %>
      <%= render "feature", feature: feature %>
    <% end %>
  </div>

  <% if @features.none? %>
    <div class="rounded-xl border border-dashed border-[var(--color-border)] bg-white p-8 text-center">
      <p class="text-sm text-[var(--color-muted)]">No features yet. Be the first to submit one.</p>
    </div>
  <% end %>

  <%= render "modal_frame", feature: Feature.new, mode: :closed %>
</section>

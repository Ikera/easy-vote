<p>Hello <%= @user.name %>,</p>

<p>We received a request to reset your password.</p>

<p>
  <%= link_to "Reset my password", url_for(controller: "passwords", action: "edit", token: @token, only_path: false), style: "color: #0f766e; font-weight: 600;" %>
</p>

<p>This link expires in 30 minutes.</p>

<p>If you did not request this, you can ignore this email.</p>
